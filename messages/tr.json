    "faq": {
      "kicker": "Sıkça sorulanlar",
      "title": "Aklındaki sorular",
      "items": {
        "q1": {
          "q": "Kurulum ne kadar sürer?",
          "a": "Ortalama 2 dakika. Kayıt ol, SMS ile doğrula, çalışma saatlerini seç, linkini paylaş. Müşterilerin hemen randevu almaya başlayabilir."
        },
        "q2": {
          "q": "SMS ücretleri kime ait?",
          "a": "Free planda SMS gönderilmez (in-app onay). Pro planda aylık 500 SMS dahildir. 500'ün üstüne çıkarsan ek SMS paketi (₺50 / 250 SMS) satın alabilirsin."
        },
        "q3": {
          "q": "Müşterilerim üye olmak zorunda mı?",
          "a": "Hayır. Müşteri linkine tıklar, slot seçer, adını + telefonunu girer, gelen 6 haneli SMS kodunu doğrular. Hesap açmaya gerek yok."
        },
        "q4": {
          "q": "Randevuyu kim iptal edebilir?",
          "a": "Hem müşteri (SMS'teki iptal linki) hem firma (panel'den). Karşı taraf otomatik bilgilendirilir."
        },
        "q5": {
          "q": "Verilerim kimin yanında?",
          "a": "Tüm veriler Supabase (KVKK uyumlu, AB sunucularında) üzerinde tutulur. Sadece sen erişebilirsin — row-level security ile başkasının görmesi mümkün değil."
        },
        "q6": {
          "q": "Çalışma saatlerimi sonradan değiştirebilir miyim?",
          "a": "Evet, ayarlardan istediğin zaman değiştir. Yeni booking'ler hemen yeni saatlere göre açılır, mevcut randevular etkilenmez."
        }
      }
    },
